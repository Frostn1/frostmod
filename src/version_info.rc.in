// FrostMod PE version resource (generated by CMake from version_info.rc.in).
//
// WHY THIS EXISTS: an unsigned Windows binary with NO version-info block is a
// strong "suspicious PE" signal to antivirus ML heuristics. Populating
// CompanyName/ProductName/FileDescription/FileVersion gives the binary a normal,
// legitimate identity and removes one of the packaging red flags. See
// docs/antivirus-false-positives.md for the full rationale.
//
// The placeholder tokens are substituted per-target by configure_file() in CMakeLists.txt.

#include <winver.h>

VS_VERSION_INFO VERSIONINFO
 FILEVERSION    @FROSTMOD_VERSION_MAJOR@,@FROSTMOD_VERSION_MINOR@,@FROSTMOD_VERSION_PATCH@,0
 PRODUCTVERSION @FROSTMOD_VERSION_MAJOR@,@FROSTMOD_VERSION_MINOR@,@FROSTMOD_VERSION_PATCH@,0
 FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
#ifdef _DEBUG
 FILEFLAGS      VS_FF_DEBUG
#else
 FILEFLAGS      0x0L
#endif
 FILEOS         VOS_NT_WINDOWS32
 FILETYPE       @FROSTMOD_RC_FILETYPE@
 FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"  // US English (0x0409), Unicode (0x04B0 = 1200)
        BEGIN
            VALUE "CompanyName",      "FrostMod"
            VALUE "FileDescription",  "@FROSTMOD_RC_FILE_DESCRIPTION@"
            VALUE "FileVersion",      "@FROSTMOD_VERSION@.0"
            VALUE "InternalName",     "@FROSTMOD_RC_ORIGINAL_FILENAME@"
            VALUE "LegalCopyright",   "Copyright (C) FrostMod contributors. MIT Licensed."
            VALUE "OriginalFilename", "@FROSTMOD_RC_ORIGINAL_FILENAME@"
            VALUE "ProductName",      "FrostMod"
            VALUE "ProductVersion",   "@FROSTMOD_VERSION@.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
